rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function sessionOwnsPatient(sessionUid, patientId) {
      return exists(/databases/$(database)/documents/sessions/$(sessionUid))
        && get(/databases/$(database)/documents/sessions/$(sessionUid)).data.patient_ids.hasAny([patientId]);
    }

    match /sessions/{sessionUid} {
      allow read, write: if isOwner(sessionUid);

      match /incidents/{incidentId} {
        allow read, write: if isOwner(sessionUid);
      }

      match /history/{historyId} {
        allow read, write: if isOwner(sessionUid);
      }
    }

    match /patients/{patientId} {
      allow read, write: if isSignedIn()
        && (
          isOwner(patientId)
          || sessionOwnsPatient(request.auth.uid, patientId)
        );

      match /medical_profile/{docId} {
        allow read, write: if isSignedIn()
          && (
            isOwner(patientId)
            || sessionOwnsPatient(request.auth.uid, patientId)
          );
      }

      match /emergency_contacts/{contactId} {
        allow read, write: if isSignedIn()
          && (
            isOwner(patientId)
            || sessionOwnsPatient(request.auth.uid, patientId)
          );
      }

      match /history/{historyId} {
        allow read: if isSignedIn()
          && (
            isOwner(patientId)
            || sessionOwnsPatient(request.auth.uid, patientId)
          );
        allow write: if false;
      }
    }

    match /incidents/{incidentId} {
      allow read: if isSignedIn() && resource.data.session_uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.session_uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.session_uid == request.auth.uid;
      allow delete: if false;
    }

    match /history/{historyId} {
      allow read: if isSignedIn() && resource.data.session_uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.session_uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
