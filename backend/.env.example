# Core backend runtime
GOOGLE_CLOUD_PROJECT=your-firebase-project-id
FIRESTORE_PROJECT_ID=your-firebase-project-id
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-service-account.json

# Optional: require Firestore instead of falling back to local sample data
FIRESTORE_REQUIRED=false

# Optional: frontend CORS/dev base assumptions
BACKEND_BASE_URL=http://127.0.0.1:8000

# Existing AI/runtime integrations
GEMINI_API_KEY=your-gemini-api-key
VERTEX_AI_SEARCH_PROJECT_ID=your-gcp-project-id
VERTEX_AI_SEARCH_LOCATION=global
VERTEX_AI_SEARCH_ENGINE_ID=your-vertex-search-engine-id
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_LOCATION=us-central1
ADK_VERTEX_SEARCH_ENGINE_ID=projects/your-project/locations/us/collections/default_collection/engines/your_engine

AGENT_BACKEND_REASONING=adk
AGENT_BACKEND_COMMUNICATION=adk
AGENT_BACKEND_EXECUTION=adk
